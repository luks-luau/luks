local h = require("../../helpers")
local zlib = require("../../../luks-std/ZLib")

return function(expect)
    h.suite("ZLib Properties", function()
        h.test("zlib exposes native module version string", function()
            expect.type_(zlib.version, "string")
            expect.true_(#zlib.version > 0)
        end)
    end)

    h.suite("ZLib Compression Verification", function()
        local repeated_payload = string.rep("Luks advanced compression stream test payload data chunks. ", 40)

        h.test("zlib compress reduces footprint of repetitive payload strings", function()
            local compressed = zlib.compress(repeated_payload)
            expect.type_(compressed, "string")
            expect.true_(#compressed < #repeated_payload)
        end)

        h.test("zlib compress handles zero-length empty string cleanly", function()
            local res = zlib.compress("")
            expect.type_(res, "string")
            expect.eq(zlib.decompress(res), "")
        end)

        h.test("zlib compress operates correctly at maximum level 9", function()
            local res = zlib.compress(repeated_payload, 9)
            expect.true_(#res < #repeated_payload)
            expect.eq(zlib.decompress(res), repeated_payload)
        end)

        h.test("zlib compress operates correctly at uncompressed level 0", function()
            local res = zlib.compress("simple uncompressed payload string", 0)
            expect.type_(res, "string")
            expect.eq(zlib.decompress(res), "simple uncompressed payload string")
        end)
    end)

    h.suite("ZLib Decompression Integrity", function()
        h.test("zlib decompress restores complete multi-byte content exactly", function()
            local source = "Zlib round-trip evaluation standard stream buffers"
            local compressed = zlib.compress(source)
            expect.eq(zlib.decompress(compressed), source)
        end)
    end)

    h.suite("ZLib Exception Resilience", function()
        h.test("zlib decompress returns error on truncated or malformed buffers", function()
            local ok, err = pcall(zlib.decompress, "malformed garbage octets sequence")
            expect.false_(ok)
            expect.type_(err, "string")
        end)

        h.test("zlib compress validates payload argument presence and typing", function()
            local ok, err = pcall(zlib.compress :: any, true)
            expect.false_(ok)
            expect.type_(err, "string")
        end)
    end)
end
