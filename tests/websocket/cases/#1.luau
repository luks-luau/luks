local h = require("../../helpers")
local WebSocket = require("../../../luks-std/WebSocket")

local ECHO_SERVER = "wss://echo.websocket.org"

return function(expect)
    h.suite("WebSocket Properties & Initialization", function()
        h.test("websocket exposes native runtime version string", function()
            expect.type_(WebSocket.version, "string")
            expect.true_(#WebSocket.version > 0)
        end)

        h.test("websocket connect instantiates complete socket interface maps", function()
            local conn = WebSocket.connect(ECHO_SERVER, { timeout = 15 })
            expect.type_(conn, "table")
            expect.type_(conn.send, "function")
            expect.type_(conn.sendBinary, "function")
            expect.type_(conn.close, "function")
            expect.type_(conn.isOpen, "function")
            expect.type_(conn.url, "function")
            expect.type_(conn.startListening, "function")
            expect.not_nil(conn.onMessage)
            expect.not_nil(conn.onClose)
            expect.not_nil(conn.onError)
            conn:close()
        end)
    end)

    h.suite("WebSocket State & Lifecycle", function()
        h.test("websocket isOpen resolves true immediately upon active handshake", function()
            local conn = WebSocket.connect(ECHO_SERVER, { timeout = 15 })
            expect.true_(conn:isOpen())
            conn:close()
        end)

        h.test("websocket url returns precise original handshake parameter string", function()
            local conn = WebSocket.connect(ECHO_SERVER, { timeout = 15 })
            expect.eq(conn:url(), ECHO_SERVER)
            conn:close()
        end)

        h.test("websocket close successfully terminates socket session allocation", function()
            local conn = WebSocket.connect(ECHO_SERVER, { timeout = 15 })
            conn:close()
            expect.false_(conn:isOpen())
        end)
    end)
end
